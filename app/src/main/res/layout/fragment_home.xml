<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF7FF"
    tools:context=".Home.HomeFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_wave"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textColor="#4A4A4A"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Card area for Cat Fact -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCatFact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#F3E5F5"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvWelcome">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvCatFact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Loading cat fact..."
                        android:textAlignment="center"
                        android:textColor="#4A4A4A"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRefresh"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Refresh"
                        android:textAllCaps="false"
                        app:backgroundTint="#673AB7"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/grid_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/cardCatFact">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToSecond"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_margin="4dp"
                    app:layout_columnWeight="1"
                    android:text="Pertemuan 2"
                    android:textAllCaps="false"
                    app:backgroundTint="#673AB7"
                    app:cornerRadius="28dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToThird"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_margin="4dp"
                    app:layout_columnWeight="1"
                    android:text="Pertemuan 3"
                    android:textAllCaps="false"
                    app:backgroundTint="#000000"
                    app:cornerRadius="28dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToFourth"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_margin="4dp"
                    app:layout_columnWeight="1"
                    android:text="Pertemuan 4"
                    android:textAllCaps="false"
                    app:backgroundTint="#757575"
                    app:cornerRadius="28dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToFifth"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_margin="4dp"
                    app:layout_columnWeight="1"
                    android:text="Pertemuan 5"
                    android:textAllCaps="false"
                    app:backgroundTint="#4285F4"
                    app:cornerRadius="28dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToSeventh"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_margin="4dp"
                    app:layout_columnWeight="1"
                    android:text="Pertemuan 7"
                    android:textAllCaps="false"
                    app:backgroundTint="#673AB7"
                    app:cornerRadius="28dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToNinth"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_margin="4dp"
                    app:layout_columnWeight="1"
                    android:text="Pertemuan 9"
                    android:textAllCaps="false"
                    app:backgroundTint="#4A148C"
                    app:cornerRadius="28dp" />

            </androidx.gridlayout.widget.GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToTenth"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="Pertemuan 10"
                android:textAllCaps="false"
                app:backgroundTint="#3F51B5"
                app:cornerRadius="28dp"
                app:layout_constraintTop_toBottomOf="@id/grid_button" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGallery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/btnToTenth" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="160dp"
                android:layout_height="50dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="#D32F2F"
                app:cornerRadius="25dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvGallery" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>