<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF7FF"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="Belajar Mobile itu Asyiik!"
            android:textColor="#4A4A4A"
            android:textSize="32sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan2"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="Pertemuan 2"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="#673AB7"
            app:cornerRadius="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan3"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="Pertemuan 3"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="#673AB7"
            app:cornerRadius="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan4"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="Pertemuan 4"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="#673AB7"
            app:cornerRadius="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan5"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="Pertemuan 5"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="#673AB7"
            app:cornerRadius="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan7"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:layout_marginBottom="48dp"
            android:text="Pertemuan 7"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="#673AB7"
            app:cornerRadius="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="180dp"
            android:layout_height="56dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#D32F2F"
            app:cornerRadius="28dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>